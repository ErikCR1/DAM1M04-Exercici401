{{> header}}


<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Panell de Control</h1>
</div>

<ul class="nav nav-tabs mb-4" id="dashboardTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="kpi-tab" data-bs-toggle="tab" data-bs-target="#kpi-content" type="button" role="tab">📊 KPI</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="llistats-tab" data-bs-toggle="tab" data-bs-target="#llistats-content" type="button" role="tab">📋 Llistats</button>
  </li>
</ul>

<div class="tab-content">
  
  <div class="tab-pane fade show active" id="kpi-content" role="tabpanel">
    <div class="mb-3">
        <button id="btn-toggle-compact" class="btn btn-sm btn-outline-secondary">Toggle Compacte / Complert</button>
    </div>

    <div id="kpi-grid" class="row g-3">
        <div class="col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Vendes Avui</h6>
                    <h2 class="fw-bold">{{kpi.vendesAvui}}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Vendes Mes</h6>
                    <h2 class="fw-bold text-primary">{{kpi.vendesMes}}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 kpi-extra">
            <div class="card text-center shadow-sm h-100 border-info">
                <div class="card-body">
                    <h6 class="text-muted">Comandes (Avui)</h6>
                    <h2 class="fw-bold">{{kpi.comandesAvui}}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 kpi-extra">
            <div class="card text-center shadow-sm h-100 border-danger">
                <div class="card-body">
                    <h6 class="text-muted">Productes Stock Baix</h6>
                    <h2 class="fw-bold text-danger">{{kpi.stockBaix.length}}</h2>
                </div>
            </div>
        </div>
    </div>
  </div>

  <div class="tab-pane fade" id="llistats-content" role="tabpanel">
    <div class="mb-3">
        <button id="btn-toggle-colors" class="btn btn-sm btn-outline-info">Activar/Desactivar Colors Stock</button>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">Últimes 5 Vendes</div>
                <table class="table mb-0">
                    <thead class="table-light"><tr><th>Data</th><th>Client</th><th>Total</th></tr></thead>
                    <tbody>
                        {{#each ultimesVendes}}
                        <tr><td>{{this.data}}</td><td>{{this.client}}</td><td>{{this.total}}€</td></tr>
                        {{else}}
                        <tr><td colspan="3" class="text-center text-muted">Cap venda registrada</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">Top 5 Productes Més Venuts</div>
                <table id="table-top-products" class="table mb-0">
                    <thead class="table-light"><tr><th>Producte</th><th>Venuts</th></tr></thead>
                    <tbody>
                        {{#each topProductes}}
                        <tr class="product-row"><td>{{this.name}}</td><td>{{this.total_vendut}} unitats</td></tr>
                        {{else}}
                        <tr><td colspan="2" class="text-center text-muted">No hi ha productes venuts</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
  </div>
</div>

<script>
    // Toggle compacte
    document.getElementById('btn-toggle-compact')?.addEventListener('click', () => {
        const extras = document.querySelectorAll('.kpi-extra');
        extras.forEach(el => el.classList.toggle('d-none'));
    });

    // Toggle colors demo
    document.getElementById('btn-toggle-colors')?.addEventListener('click', () => {
        const rows = document.querySelectorAll('.product-row');
        rows.forEach((row, index) => {
            // Marca fila
            row.classList.toggle('table-warning');
        });
    });
</script>

{{> footer}}