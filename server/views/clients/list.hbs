{{> header}}


<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Llistat de Clients</h2>
    <a href="/clientAfegir" class="btn btn-primary">+ Afegir Client</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form action="/clients" method="GET" class="row g-3 align-items-center">
            <div class="col-md-6">
                <input type="text" name="cerca" value="{{cerca}}" class="form-control" placeholder="Cercar per nom o email...">
            </div>
            <div class="col-md-4">
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" name="vip" value="1" id="vipCheck" {{#if vip}}checked{{/if}}>
                    <label class="form-check-label" for="vipCheck">
                        Només Clients VIP (> 100€ gastats)
                    </label>
                </div>
            </div>
            <div class="col-md-2 text-end">
                <input type="hidden" name="pagina" value="0">
                <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>


<div class="table-responsive">
    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Email</th>
                <th>Telèfon</th>
                <th>Núm. Compres</th>
                <th>Total Gastat</th>
                <th>Accions</th>
            </tr>
        </thead>
        <tbody>
            {{#each clients}}
            <tr>
                <td>{{this.id}}</td>
                <td><strong>{{this.name}}</strong></td>
                <td>{{this.email}}</td>
                <td>{{this.phone}}</td>
                <td>{{this.num_compres}}</td>
                <td>{{this.total_gastat}} €</td>
                <td>
                    <a href="/clientFitxa?id={{this.id}}" class="btn btn-sm btn-info text-white">Fitxa</a>
                    <a href="/clientEditar?id={{this.id}}" class="btn btn-sm btn-warning">Editar</a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="7" class="text-center py-4">No s'han trobat clients amb aquests criteris.</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between mt-4">
    <a href="/clients?pagina={{resta pagina 1}}&cerca={{cerca}}&vip={{#if vip}}1{{else}}0{{/if}}" class="btn btn-outline-primary {{#if (eq pagina 0)}}disabled{{/if}}">&laquo; Anterior</a>

    <span class="align-self-center text-muted">Pàgina {{suma pagina 1}} de {{totalPages}}</span>

    <a href="/clients?pagina={{suma pagina 1}}&cerca={{cerca}}&vip={{#if vip}}1{{else}}0{{/if}}" class="btn btn-outline-primary {{#if (eq (suma pagina 1) totalPages)}}disabled{{/if}}">Següent &raquo;</a>
</div>

{{> footer}}