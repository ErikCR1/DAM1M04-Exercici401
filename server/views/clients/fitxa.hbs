{{> header}}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Fitxa del Client: {{client.name}}</h2>
    <a href="/clients" class="btn btn-secondary">Tornar al llistat</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-info">
            <div class="card-header bg-info text-white">Dades de Contacte</div>
            <div class="card-body">
                <p><strong>Email:</strong> {{client.email}}</p>
                <p><strong>Telèfon:</strong> {{#if client.phone}}{{client.phone}}{{else}}<span class="text-muted">No informat</span>{{/if}}</p>
                <a href="/clientEditar?id={{client.id}}" class="btn btn-sm btn-outline-primary mt-2">Editar Dades</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex justify-content-around align-items-center text-center">
                <div>
                    <h5 class="text-muted">Total Gastat</h5>
                    <h2 class="text-success">{{totalGastat}} €</h2>
                </div>
                <div>
                    <h5 class="text-muted">Ticket Mitjà</h5>
                    <h2 class="text-primary">{{ticketMitja}} €</h2>
                </div>
            </div>
        </div>
    </div>
</div>

<h4>Historial de Compres (Últimes 10)</h4>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped m-0">
            <thead class="table-dark">
                <tr>
                    <th>Data de Venda</th>
                    <th>ID Venda</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                {{#each vendes}}
                <tr>
                    <td>{{this.sale_date}}</td>
                    <td>#{{this.id}}</td>
                    <td class="text-end fw-bold">{{this.total}} €</td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="3" class="text-center py-3">Aquest client encara no ha fet cap compra.</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>
{{> footer}}