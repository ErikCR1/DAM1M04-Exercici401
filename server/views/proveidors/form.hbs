{{> header}}

<h2 class="mb-4">{{#if proveidor.id}}Editar Proveïdor{{else}}Nou Proveïdor{{/if}}</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form id="proveidor-form" action="{{#if proveidor.id}}/Update{{else}}/create{{/if}}" method="POST" novalidate>
            <input type="hidden" name="taula" value="proveidors">
            {{#if proveidor.id}}<input type="hidden" name="id" value="{{proveidor.id}}">{{/if}}

            <div class="mb-3">
                <label for="name" class="form-label">Nom comercial <span class="text-danger"></span></label>
                <input type="text" id="name" name="name" value="{{proveidor.name}}" class="form-control" required>
                <div class="invalid-feedback" id="error-name">El nom es obligatori.</div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Correu electronic <span class="text-danger"></span></label>
                <input type="email" id="email" name="email" value="{{proveidor.email}}" class="form-control" required>
                <div class="invalid-feedback" id="error-email">Introdueix un email valid.</div>
            </div>

            <div class="mb-4">
                <label for="phone" class="form-label">Telefon (minim 9 xifres)</label>
                <input type="text" id="phone" name="phone" value="{{proveidor.phone}}" class="form-control">
                <div class="invalid-feedback" id="error-phone">El telefon ha de tenir almenys 9 caracters.</div>
            </div>

            <button type="submit" class="btn btn-success">Guardar Proveïdor</button>
            <a href="/proveidors" class="btn btn-secondary">Cancel·lar</a>
        </form>
    </div>
</div>
{{#if proveidor.id}}
<div class="mt-4 text-end">
    <form action="/Delete" method="POST" onsubmit="return confirm('ATENCIO: Segur que vols esborrar aquest proveidor?');">
        <input type="hidden" name="taula" value="proveidors">
        <input type="hidden" name="id" value="{{proveidor.id}}">
        <button type="submit" class="btn btn-danger">Esborrar Proveïdor</button>
    </form>
</div>
{{/if}}

{{> footer}}
